# Copy this file to .env and fill your real values
# .env ko kabhi bhi GitHub par push mat karna

DATABASE_URL=sqlite:///./localkirana.db
# Production mein PostgreSQL use karo, jaise:
# DATABASE_URL=postgresql://user:password@localhost/localkirana

SECRET_KEY=change-this-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Razorpay dashboard (https://dashboard.razorpay.com) se milega
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx

# Google Cloud Console (https://console.cloud.google.com) se milega
# Maps JavaScript API + Geocoding API enable karna
GOOGLE_MAPS_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Kitne online payments ke baad customer cash-on-pickup ka eligible hoga
ONLINE_PAYMENTS_REQUIRED_FOR_CASH=10
